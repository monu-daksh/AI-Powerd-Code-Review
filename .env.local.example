# ─── AI Provider ───────────────────────────────────────────────────────────────
# Choose "ollama" for free local models or "anthropic" for the paid API
AI_PROVIDER=ollama

# ─── Ollama (Free / Local) ─────────────────────────────────────────────────────
# Run Ollama locally: https://ollama.ai
# Pull a model first: ollama pull codellama  OR  ollama pull deepseek-coder
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=codellama
# Other good free options: deepseek-coder, mistral, llama3.2, qwen2.5-coder

# ─── Anthropic (Paid / Future) ─────────────────────────────────────────────────
# TODO: Uncomment and set this key when you want to switch to Claude
# Get your key at: https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-6

# ─── GitHub (for CI/CD PR comments) ────────────────────────────────────────────
# Personal access token with repo + pull_requests scope
# GITHUB_TOKEN=ghp_...
